NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
MONGODB_DB=prompthive
MONGODB_CONNECT_RETRIES=5
MONGODB_CONNECT_RETRY_DELAY_MS=1500

# Better Auth
BETTER_AUTH_URL=http://localhost:5000
BETTER_AUTH_SECRET=replace-with-a-strong-32-character-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe premium payment
STRIPE_SECRET_KEY=sk_test_replace_me
PREMIUM_PRICE_USD=5

# Optional prompt tester
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Seed/admin helper
DEFAULT_ADMIN_NAME=PromptHive Admin
DEFAULT_ADMIN_EMAIL=admin@demo.com
DEFAULT_ADMIN_PASSWORD=admin1234
